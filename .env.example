# Token do bot criado no BotFather
BOT_TOKEN=1234567890:AAEXAMPLE_TOKEN_HERE

# IDs do Telegram autorizados, separados por vírgula
ALLOWED_USERS=123456789,987654321

# Diretório onde os vídeos baixados serão salvos
DOWNLOAD_DIR=./downloads

# Caminho do banco SQLite
DB_PATH=./cache_db/cache.db

# Qualidade preferida na hora de filtrar streams
DEFAULT_QUALITY=1080p

# Preferência de idioma para legendas, separado por vírgula (prioridade da esquerda para direita)
# Exemplos: SUB_LANG=pt-br,pt,en
# Se uma legenda preferida for encontrada, o bot enviará automaticamente essa legenda sem perguntar.
SUB_LANG=pt-br,pt

# Se true, mantém a cópia temporária da legenda renomeada após o envio.
KEEP_SUBTITLE_COPY=false

# Rotação de logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
